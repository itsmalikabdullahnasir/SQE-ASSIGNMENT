name: CI – Search Library MC/DC Tests

on:
  push:
    branches: [ "main", "develop" ]
  pull_request:
    branches: [ "main", "develop" ]
  workflow_dispatch:

jobs:

  build-and-test:
    name: Build · Run 37 MC/DC Tests · Coverage Report
    runs-on: ubuntu-latest

    steps:

      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up JDK 11
        uses: actions/setup-java@v4
        with:
          java-version: '11'
          distribution: 'temurin'
          cache: 'maven'

      - name: Run all MC/DC tests + coverage check
        run: mvn --batch-mode clean verify
        # 'verify' runs: compile → test → jacoco:report → jacoco:check
        # All in one step — no separate jacoco:check call needed

      - name: Upload JaCoCo coverage report
        uses: actions/upload-artifact@v4
        if: always()
        with:
          name: jacoco-coverage-report
          path: target/site/jacoco/
          retention-days: 14

      - name: Upload Surefire test results
        uses: actions/upload-artifact@v4
        if: always()
        with:
          name: surefire-test-results
          path: target/surefire-reports/
          retention-days: 14
